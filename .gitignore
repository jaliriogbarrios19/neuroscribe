# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Rust / Tauri
/src-tauri/target
/src-tauri/gen
# Permitir específicamente los sidecars para el build de GitHub
!/src-tauri/bin/whisper/whisper-cli-x86_64-pc-windows-msvc.exe
!/src-tauri/bin/llama/llama-cli-x86_64-pc-windows-msvc.exe

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.db
*.db-journal

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
