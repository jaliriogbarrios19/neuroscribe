{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NeuroScribe",
  "version": "1.0.0",
  "identifier": "app.neuroscribe.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NeuroScribe",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' https://eutils.ncbi.nlm.nih.gov https://api.openalex.org https://api.crossref.org https://huggingface.co https://models.neuroscribe.app; img-src 'self' data: asset: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/whisper/whisper-cli",
      "bin/llama/llama-cli"
    ]
  }
}
