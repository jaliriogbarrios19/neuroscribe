{
  "identifier": "default",
  "description": "enables the default permissions for NeuroScribe",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "fs:default",
    "os:default",
    "log:default",
    "sql:default",
    "neuroscribe:allow-neuroscribe-commands"
  ]
}
